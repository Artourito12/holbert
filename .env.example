# Supabase — projet Holbert (dashboard > Settings > API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Clé secrète service_role — UNIQUEMENT côté serveur (fonctions api/), jamais exposée au front
SUPABASE_SERVICE_ROLE_KEY=

# IA (jalon 2+)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Légifrance via PISTE (https://piste.gouv.fr — créer un compte, souscrire à
# l'API Légifrance, copier les identifiants OAuth). Optionnel : sans ces clés,
# les citations pointent vers la recherche legifrance.gouv.fr.
LEGIFRANCE_CLIENT_ID=
LEGIFRANCE_CLIENT_SECRET=

# Emails (https://resend.com — compte gratuit, domaine vérifié recommandé).
# Optionnel : sans clé, alertes et invitations restent in-app uniquement.
RESEND_API_KEY=
EMAIL_FROM=Holbert <notifications@votre-domaine.fr>
# URL publique de l'app (liens dans les emails d'invitation)
APP_URL=
